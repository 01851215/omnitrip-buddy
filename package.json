{
  "private": true,
  "name": "omnitrip-monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "web": "turbo run dev --filter=omnitrip-web",
    "mobile": "turbo run dev --filter=omnitrip-mobile"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "~5.7.2"
  },
  "packageManager": "npm@10.0.0"
}
