{
  "name": "@omnitrip/shared",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./services/*": "./src/services/*.ts",
    "./stores/*": "./src/stores/*.ts",
    "./i18n/*": "./src/i18n/*.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./data/*": "./src/data/*.ts",
    "./platform": "./src/platform/index.ts",
    "./platform/*": "./src/platform/*.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsc --noEmit --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "zustand": ">=4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "~5.7.2"
  }
}
