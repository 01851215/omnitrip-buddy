# ── Spline (Buddy 3D character) ──
# Default runtime URL is set in buddySplineScene.ts (scene.splinecode).
# VITE_SPLINE_SCENE_URL=https://prod.spline.design/76ZfQ3971TWWhcYf/scene.splinecode
# VITE_SPLINE_SCENE_URL=   ← empty = use iframe (my.spline viewer) instead
# VITE_SPLINE_VIEWER_URL=https://my.spline.design/your-scene/
# VITE_BUDDY_USE_SPLINE=0  ← PNG + CSS Buddy instead of Spline

# ── Supabase ──
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# ── AI / LLM ──
# VITE_CLAUDE_API_KEY=sk-ant-...

# ── Voice ──
# VITE_ELEVENLABS_API_KEY=...

# ── OpenAI Model ──
# VITE_OPENAI_MODEL=gpt-5.4

# ── Amadeus API (for real-time flight/hotel/activity prices) ──
# Sign up: https://developers.amadeus.com → Create Self-Service App → Get API Key + Secret
# AMADEUS_API_KEY=...
# AMADEUS_API_SECRET=...

# ── Stripe (for in-app activity bookings + wallet) ──
# Sign up: https://dashboard.stripe.com → Developers → API Keys
# STRIPE_SECRET_KEY=sk_test_...          (Supabase secret — set via `supabase secrets set`)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_... (Frontend — add to .env and Vercel env vars)
# STRIPE_WEBHOOK_SECRET=whsec_...        (Supabase secret)

# ── Kiwi.com Tequila (optional, supplementary flights/trains) ──
# Sign up: https://tequila.kiwi.com
# KIWI_API_KEY=...

# ── Google Calendar OAuth (for calendar sync) ──
# Create: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Enable: Google Calendar API
# Authorized redirect URI: https://your-domain.com/auth/calendar/callback
# VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# ── Microsoft Outlook OAuth (for calendar sync) ──
# Create: https://portal.azure.com → App registrations → New registration (SPA)
# API Permissions: Microsoft Graph → Calendars.ReadWrite
# Redirect URI: https://your-domain.com/auth/calendar/callback
# VITE_MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Maps & Places ──
# VITE_MAPBOX_TOKEN=pk.ey...
# VITE_FOURSQUARE_API_KEY=fsq...
